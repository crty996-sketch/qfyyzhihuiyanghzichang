rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'anonymous'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Role checks
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isVerified() && getUserData().role == 'admin'; }
    function isOperator() { return isVerified() && (getUserData().role == 'admin' || getUserData().role == 'operator'); }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.username is string && data.username.size() <= 32 &&
             data.role in ['admin', 'operator', 'viewer'] &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 64));
    }

    function isValidTank(data) {
      return data.id is string && data.id.size() <= 20 &&
             data.status in ['normal', 'alarm', 'empty', 'maintenance'] &&
             (data.temperature == null || data.temperature is number) &&
             (data.ph == null || data.ph is number);
    }

    function isValidRecord(data) {
      return data.date is string && data.date.size() == 10 &&
             data.tankId is string && data.tankId.size() <= 20;
    }

    // --- Rules ---

    // Users
    match /users/{userId} {
      allow read: if isVerified();
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isVerified() && (request.auth.uid == userId || isAdmin()) && isValidUser(incoming()) &&
                    (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']));
    }

    // Tanks
    match /tanks/{tankId} {
      allow get: if isVerified() || request.auth.token.firebase.sign_in_provider == 'anonymous';
      allow list: if isVerified();
      allow write: if isOperator() && isValidId(tankId) && isValidTank(incoming());
    }

    // Records
    match /records_inout/{recordId} {
      allow read: if isVerified();
      allow create: if isOperator() && isValidRecord(incoming()) && incoming().type in ['purchaseIn', 'transferIn', 'salesOut', 'transferOut'];
      allow update, delete: if isAdmin();
    }

    match /records_feedmed/{recordId} {
      allow read: if isVerified();
      allow create: if isOperator() && isValidRecord(incoming());
      allow update, delete: if isAdmin();
    }

    match /records_loss/{recordId} {
      allow read: if isVerified();
      allow create: if isOperator() && isValidRecord(incoming());
      allow update, delete: if isAdmin();
    }

    // Traceability (Public Read Access)
    match /traceability/{traceId} {
      allow read: if true; // Public access for QR codes
      allow write: if isOperator() && isValidId(traceId);
    }

    // Settings
    match /settings/branding {
      allow read: if true; // Publicly available for UI initialization
      allow write: if isAdmin();
    }
  }
}
